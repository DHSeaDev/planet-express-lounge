{
  "manifest_version": 3,
  "name": "Planet Express Lounge",
  "version": "4.1.0",
  "description": "Chat with the Futurama crew. AI-powered sitcom engine \u2014 no server required. Unofficial fan project.",
  "homepage_url": "https://github.com/dhseadev/planet-express-lounge",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Planet Express Sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "sidePanel",
    "tts",
    "alarms"
  ],
  "host_permissions": [
    "https://api.groq.com/*",
    "https://openrouter.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.elevenlabs.io/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac": "Alt+Shift+P"
      },
      "description": "Open Planet Express Sidebar"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
  },
  "author": "#DHSeaDev \u2014 fan project"
}